<html>
<head>
    <title><% title %></title>
</head>
<body>
    <h1>Welcome to Herbist</h1>
    <p>Connected to MariaDB version: <% version %></p>

    <p>
        <strong>Main:</strong> <a href="/add">Add New Herb</a>
    </p>
    <p>
        <strong>Manage Tables:</strong>
        <a href="/manage/constituents">Constituents</a> | 
        <a href="/manage/actions">Actions</a> | 
        <a href="/manage/energetics">Energetics</a> | 
        <a href="/manage/indications">Indications</a> | 
        <a href="/manage/plantfamily">Plant Family</a> | 
        <a href="/manage/bodysystems">Body Systems</a>
    </p>

    <h2>Herb List</h2>
    <% IF herbs.size %>
        <table border="1" cellpadding="10">
            <thead>
                <tr>
                    <th>Photo</th>
                    <th>Common Name</th>
                    <th>Latin Name</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                <% FOREACH herb IN herbs %>
                    <tr>
                        <td align="center">
                            <% IF herb.image_path %>
                                <img src="<% herb.image_path %>" alt="<% herb.common_name %>" width="100">
                            <% ELSE %>
                                No Photo
                            <% END %>
                        </td>
                        <td><% herb.common_name %></td>
                        <td><% herb.latin_name %></td>
                        <td><% herb.description %></td>
                        <td>
                            <a href="/herb/<% herb.ID %>">View</a> |
                            <a href="/herb/<% herb.ID %>/edit">Edit</a> |
                            <form action="/herb/<% herb.ID %>/delete" method="post" style="display:inline;" onsubmit="return confirm('Really delete this herb?')">
                                <button type="submit" style="color: red; background: none; border: none; cursor: pointer; text-decoration: underline; padding: 0;">Delete</button>
                            </form>
                        </td>
                    </tr>
                <% END %>
            </tbody>
        </table>
    <% ELSE %>
        <p>No herbs found in the database.</p>
    <% END %>
</body>
</html>
