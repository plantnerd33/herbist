<html>
<head>
    <title><% title %></title>
</head>
<body>
    <h1>Welcome to Herbist</h1>
    <p>Connected to MariaDB version: <% version %></p>

    <p><a href="/add">Add New Herb</a></p>

    <h2>Herb List</h2>
    <% IF herbs.size %>
        <table border="1" cellpadding="10">
            <thead>
                <tr>
                    <th>Photo</th>
                    <th>Common Name</th>
                    <th>Latin Name</th>
                    <th>Description</th>
                    <th>Manage</th>
                </tr>
            </thead>
            <tbody>
                <% FOREACH herb IN herbs %>
                    <tr>
                        <td align="center">
                            <% IF herb.image_path %>
                                <img src="<% herb.image_path %>" alt="<% herb.common_name %>" width="100">
                            <% ELSE %>
                                No Photo
                            <% END %>
                        </td>
                        <td><% herb.common_name %></td>
                        <td><% herb.latin_name %></td>
                        <td><% herb.description %></td>
                        <td><a href="/herb/<% herb.ID %>">Manage Details</a></td>
                    </tr>
                <% END %>
            </tbody>
        </table>
    <% ELSE %>
        <p>No herbs found in the database.</p>
    <% END %>
</body>
</html>
